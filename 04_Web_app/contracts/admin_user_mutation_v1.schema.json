{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x5-mmm.local/contracts/admin_user_mutation_v1.schema.json",
  "title": "Admin User Mutation V1",
  "oneOf": [
    {
      "title": "Create local pilot user",
      "type": "object",
      "additionalProperties": false,
      "required": ["email", "display_name", "password", "role_id"],
      "properties": {
        "email": {"type": "string", "format": "email", "maxLength": 254},
        "display_name": {"type": "string", "minLength": 2, "maxLength": 120},
        "password": {"type": "string", "minLength": 12, "maxLength": 256, "writeOnly": true},
        "role_id": {"enum": ["viewer", "analyst", "admin"]}
      }
    },
    {
      "title": "Update local pilot user",
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "display_name": {"type": "string", "minLength": 2, "maxLength": 120},
        "role_id": {"enum": ["viewer", "analyst", "admin"]}
      }
    }
  ]
}
