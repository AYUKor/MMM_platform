{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmm-platform.local/contracts/job_result_view_v2.schema.json",
  "title": "JobResultViewV2",
  "oneOf": [{"$ref": "#/$defs/jobResultViewV2"}],
  "$defs": {
    "quantiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "unit", "p10", "p50", "p90", "display_text"],
      "properties": {
        "status": {"enum": ["available", "unavailable"]},
        "unit": {"type": "string"},
        "p10": {"type": ["number", "null"]},
        "p50": {"type": ["number", "null"]},
        "p90": {"type": ["number", "null"]},
        "display_text": {"type": "string", "minLength": 1}
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_budget_rub", "allocated_budget_rub", "unallocated_budget_rub", "allocation_share"],
      "properties": {
        "requested_budget_rub": {"type": "number", "minimum": 0},
        "allocated_budget_rub": {"type": "number", "minimum": 0},
        "unallocated_budget_rub": {"type": "number", "minimum": 0},
        "allocation_share": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      }
    },
    "riskBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["within_support_budget_rub", "within_support_share", "controlled_extrapolation_budget_rub", "controlled_extrapolation_share", "high_risk_budget_rub", "high_risk_share", "within_support_cells_n", "controlled_extrapolation_cells_n", "high_risk_cells_n"],
      "properties": {
        "within_support_budget_rub": {"type": "number", "minimum": 0},
        "within_support_share": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "controlled_extrapolation_budget_rub": {"type": "number", "minimum": 0},
        "controlled_extrapolation_share": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "high_risk_budget_rub": {"type": "number", "minimum": 0},
        "high_risk_share": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "within_support_cells_n": {"type": "integer", "minimum": 0},
        "controlled_extrapolation_cells_n": {"type": "integer", "minimum": 0},
        "high_risk_cells_n": {"type": "integer", "minimum": 0}
      }
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "channel_display_name"],
      "properties": {
        "channel_id": {"type": "string", "minLength": 1},
        "channel_display_name": {"type": "string", "minLength": 1}
      }
    },
    "geo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geo_id", "geo_display_name"],
      "properties": {
        "geo_id": {"type": "string", "pattern": "^geo_[0-9a-f]{16}$"},
        "geo_display_name": {"type": "string", "minLength": 1}
      }
    },
    "geoPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["geo_id", "geo_display_name", "latitude", "longitude", "coordinates_status"],
      "properties": {
        "geo_id": {"type": "string", "pattern": "^geo_[0-9a-f]{16}$"},
        "geo_display_name": {"type": "string", "minLength": 1},
        "latitude": {"type": ["number", "null"], "minimum": -90, "maximum": 90},
        "longitude": {"type": ["number", "null"], "minimum": -180, "maximum": 180},
        "coordinates_status": {"enum": ["canonical", "unavailable"]},
        "region_id": {"type": ["string", "null"]},
        "region_display_name": {"type": ["string", "null"]}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scenario_id", "name", "description", "scenario_kind", "scenario_variant", "status", "is_recommended", "decision_status", "review_status", "budget", "incremental_turnover", "roas", "risk_budget", "reliability", "limiting_constraints"],
      "properties": {
        "scenario_id": {"enum": ["S01", "S02", "S03", "S04", "S05", "S06"]},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "scenario_kind": {"enum": ["uploaded_plan", "benchmark_plan", "conservative_plan", "optimized_plan"]},
        "scenario_variant": {"type": ["string", "null"]},
        "status": {"enum": ["completed", "infeasible", "unavailable"]},
        "is_recommended": {"type": "boolean"},
        "decision_status": {"enum": ["recommended_reallocation", "keep_uploaded_plan", "manual_review_required", "no_safe_recommendation", "unavailable"]},
        "review_status": {"enum": ["not_required", "manual_review_required"]},
        "budget": {"$ref": "#/$defs/budget"},
        "incremental_turnover": {"$ref": "#/$defs/quantiles"},
        "roas": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allocated_budget", "requested_budget", "primary_denominator_kind", "primary_denominator_budget_rub"],
          "properties": {
            "allocated_budget": {"$ref": "#/$defs/quantiles"},
            "requested_budget": {"$ref": "#/$defs/quantiles"},
            "primary_denominator_kind": {"enum": ["allocated_budget", "requested_budget"]},
            "primary_denominator_budget_rub": {"type": "number", "minimum": 0}
          }
        },
        "risk_budget": {"$ref": "#/$defs/riskBudget"},
        "reliability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "display_text", "evidence_codes", "safe_rank", "raw_rank"],
          "properties": {
            "status": {"enum": ["within_support", "controlled_extrapolation", "high_risk", "manual_review", "unavailable"]},
            "display_text": {"type": "string", "minLength": 1},
            "evidence_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
            "safe_rank": {"type": ["integer", "null"], "minimum": 1},
            "raw_rank": {"type": ["integer", "null"], "minimum": 1}
          }
        },
        "limiting_constraints": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "jobResultViewV2": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_name", "schema_version", "record_origin", "job_id", "result_id", "source_overview_id", "updated_at_utc", "campaign", "recommendation", "scenarios", "media_plan", "map", "limitations"],
      "properties": {
        "contract_name": {"const": "job_result_view_v2"},
        "schema_version": {"const": "2.0.0"},
        "record_origin": {"enum": ["application_runtime", "sanitized_fixture"]},
        "job_id": {"type": "string"},
        "result_id": {"type": "string"},
        "source_overview_id": {"type": "string"},
        "updated_at_utc": {"type": "string", "format": "date-time"},
        "campaign": {
          "type": "object",
          "additionalProperties": false,
          "required": ["campaign_id", "campaign_name", "segments", "start_date", "end_date", "requested_budget_rub", "channels", "geographies_n", "geographies"],
          "properties": {
            "campaign_id": {"type": "string"},
            "campaign_name": {"type": "string", "minLength": 1},
            "segments": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
            "start_date": {"type": "string", "format": "date"},
            "end_date": {"type": "string", "format": "date"},
            "requested_budget_rub": {"type": "number", "minimum": 0},
            "channels": {"type": "array", "items": {"$ref": "#/$defs/channel"}, "uniqueItems": true},
            "geographies_n": {"type": "integer", "minimum": 0},
            "geographies": {"type": "array", "items": {"$ref": "#/$defs/geo"}}
          }
        },
        "recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["decision_status", "review_status", "scenario_id", "title", "display_text", "decision_scope_text"],
          "properties": {
            "decision_status": {"enum": ["recommended_reallocation", "keep_uploaded_plan", "manual_review_required", "no_safe_recommendation", "unavailable"]},
            "review_status": {"enum": ["not_required", "manual_review_required"]},
            "scenario_id": {"type": ["string", "null"]},
            "title": {"type": "string", "minLength": 1},
            "display_text": {"type": "string", "minLength": 1},
            "decision_scope_text": {"type": "string", "minLength": 1}
          }
        },
        "scenarios": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/scenario"}},
        "media_plan": {
          "type": "object",
          "additionalProperties": false,
          "required": ["endpoint", "selected_scenario_id"],
          "properties": {
            "endpoint": {"type": "string", "pattern": "^/api/v1/jobs/[^/]+/media-plan-v2$"},
            "selected_scenario_id": {"type": "string"}
          }
        },
        "map": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "display_text", "coordinate_catalog_version", "geo_points"],
          "properties": {
            "status": {"enum": ["available", "partial", "unavailable"]},
            "display_text": {"type": "string", "minLength": 1},
            "coordinate_catalog_version": {"type": "string"},
            "geo_points": {"type": "array", "items": {"$ref": "#/$defs/geoPoint"}}
          }
        },
        "limitations": {"type": "array", "items": {"type": "object", "required": ["code", "display_text"], "properties": {"code": {"type": "string"}, "display_text": {"type": "string"}}, "additionalProperties": false}}
      }
    }
  }
}
