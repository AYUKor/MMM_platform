{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x5.example/contracts/calculation_history_v1.schema.json",
  "title": "CalculationHistoryV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_name",
    "schema_version",
    "record_origin",
    "summary",
    "filters",
    "pagination",
    "items",
    "updated_at_utc"
  ],
  "properties": {
    "contract_name": { "const": "calculation_history_v1" },
    "schema_version": { "const": "1.0.0" },
    "record_origin": { "enum": ["application_runtime", "synthetic_fixture"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["all", "active", "succeeded", "failed", "cancelled", "timed_out"],
      "properties": {
        "all": { "type": "integer", "minimum": 0 },
        "active": { "type": "integer", "minimum": 0 },
        "succeeded": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "cancelled": { "type": "integer", "minimum": 0 },
        "timed_out": { "type": "integer", "minimum": 0 }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "search", "created_from", "created_to", "sort"],
      "properties": {
        "status": {
          "type": ["string", "null"],
          "enum": [null, "active", "queued", "running", "cancel_requested", "succeeded", "failed", "cancelled", "timed_out"]
        },
        "search": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 },
        "created_from": { "type": ["string", "null"], "format": "date" },
        "created_to": { "type": ["string", "null"], "format": "date" },
        "sort": { "enum": ["created_desc", "created_asc", "completed_desc", "campaign_asc"] }
      }
    },
    "pagination": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "page_size", "total_items", "total_pages"],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "page_size": { "type": "integer", "minimum": 1, "maximum": 100 },
        "total_items": { "type": "integer", "minimum": 0 },
        "total_pages": { "type": "integer", "minimum": 0 }
      }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/historyItem" }
    },
    "updated_at_utc": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*_[0-9a-f]{12,64}$"
    },
    "internalPath": { "type": "string", "pattern": "^/(?!Users/|home/|private/|tmp/|var/)" },
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": { "type": "string", "format": "date" },
        "end_date": { "type": "string", "format": "date" }
      }
    },
    "historyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "job_id",
        "campaign_name",
        "created_at_utc",
        "completed_at_utc",
        "status",
        "status_display_text",
        "campaign_period",
        "total_budget_rub",
        "segments",
        "channels_n",
        "geographies_n",
        "result_available",
        "report_available",
        "progress_path",
        "result_path",
        "warnings_count"
      ],
      "properties": {
        "job_id": { "$ref": "#/$defs/opaqueId" },
        "campaign_name": { "type": "string", "minLength": 1 },
        "created_at_utc": { "type": "string", "format": "date-time" },
        "completed_at_utc": { "type": ["string", "null"], "format": "date-time" },
        "status": {
          "enum": ["queued", "running", "cancel_requested", "succeeded", "failed", "cancelled", "timed_out"]
        },
        "status_display_text": { "type": "string", "minLength": 1 },
        "campaign_period": {
          "oneOf": [{ "$ref": "#/$defs/period" }, { "type": "null" }]
        },
        "total_budget_rub": { "type": ["number", "null"], "minimum": 0 },
        "segments": {
          "oneOf": [
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            { "type": "null" }
          ]
        },
        "channels_n": { "type": ["integer", "null"], "minimum": 0 },
        "geographies_n": { "type": ["integer", "null"], "minimum": 0 },
        "result_available": { "type": "boolean" },
        "report_available": { "type": "boolean" },
        "progress_path": { "$ref": "#/$defs/internalPath" },
        "result_path": {
          "oneOf": [{ "$ref": "#/$defs/internalPath" }, { "type": "null" }]
        },
        "warnings_count": { "type": ["integer", "null"], "minimum": 0 }
      }
    }
  }
}
