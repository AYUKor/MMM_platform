{
  "openapi": "3.1.0",
  "info": {
    "title": "X5 MMM Research Product API",
    "version": "1.9.0",
    "description": "Versioned HTTP boundary for local pilot authentication, administration, campaign upload, validation, asynchronous calculation jobs, browser-safe progress, results, product navigation, model information, help and artifacts. The API contains no MMM mathematics."
  },
  "servers": [{"url": "/", "description": "Same-origin reverse proxy or localhost"}],
  "security": [{"sessionCookie": []}],
  "paths": {
    "/health": {
      "get": {"security": [], "operationId": "getHealth", "responses": {"200": {"description": "Process liveness"}}}
    },
    "/ready": {
      "get": {
        "security": [],
        "operationId": "getReadiness",
        "responses": {
          "200": {"description": "Package, upload service and local stores are ready"},
          "503": {"description": "One or more serving dependencies are not ready"}
        }
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "security": [],
        "operationId": "loginLocalPilotUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": false,
                "required": ["email", "password"],
                "properties": {
                  "email": {"type": "string", "format": "email", "maxLength": 254},
                  "password": {"type": "string", "maxLength": 256, "writeOnly": true}
                }
              }
            }
          }
        },
        "responses": {
          "200": {"description": "Authenticated server-side session", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AuthSession"}}}},
          "401": {"$ref": "#/components/responses/ApiError"},
          "429": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "security": [],
        "operationId": "logoutLocalPilotUser",
        "responses": {
          "200": {"description": "Anonymous session after idempotent logout", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AuthSession"}}}}
        }
      }
    },
    "/api/v1/auth/session": {
      "get": {
        "security": [],
        "operationId": "getCurrentAuthSession",
        "responses": {
          "200": {"description": "Authenticated or anonymous session state", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AuthSession"}}}}
        }
      }
    },
    "/api/v1/admin/users": {
      "get": {
        "operationId": "listAdminUsers",
        "parameters": [
          {"$ref": "#/components/parameters/AdminPage"},
          {"$ref": "#/components/parameters/AdminPageSize"},
          {"$ref": "#/components/parameters/AdminSearch"},
          {"$ref": "#/components/parameters/AdminRole"},
          {"$ref": "#/components/parameters/AdminUserStatus"},
          {"$ref": "#/components/parameters/AdminUserSort"}
        ],
        "responses": {
          "200": {"description": "Filtered local pilot users", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserList"}}}},
          "401": {"$ref": "#/components/responses/ApiError"},
          "403": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"}
        }
      },
      "post": {
        "operationId": "createAdminUser",
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserMutation"}}}},
        "responses": {
          "201": {"description": "Created local pilot user", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserDetail"}}}},
          "401": {"$ref": "#/components/responses/ApiError"},
          "403": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/admin/users/{user_id}": {
      "get": {
        "operationId": "getAdminUser",
        "parameters": [{"$ref": "#/components/parameters/UserId"}],
        "responses": {
          "200": {"description": "Local pilot user detail", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserDetail"}}}},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      },
      "patch": {
        "operationId": "updateAdminUser",
        "parameters": [{"$ref": "#/components/parameters/UserId"}],
        "requestBody": {"required": true, "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserMutation"}}}},
        "responses": {
          "200": {"description": "Updated local pilot user", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserDetail"}}}},
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/admin/users/{user_id}/disable": {
      "post": {
        "operationId": "disableAdminUser",
        "parameters": [{"$ref": "#/components/parameters/UserId"}],
        "responses": {
          "200": {"description": "Disabled user with all sessions revoked", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserDetail"}}}},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/admin/users/{user_id}/enable": {
      "post": {
        "operationId": "enableAdminUser",
        "parameters": [{"$ref": "#/components/parameters/UserId"}],
        "responses": {
          "200": {"description": "Enabled user", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminUserDetail"}}}}
        }
      }
    },
    "/api/v1/admin/users/{user_id}/sessions/revoke": {
      "post": {
        "operationId": "revokeAdminUserSessions",
        "parameters": [{"$ref": "#/components/parameters/UserId"}],
        "responses": {"200": {"description": "Number of revoked sessions"}}
      }
    },
    "/api/v1/admin/roles": {
      "get": {
        "operationId": "getAdminRoleCatalog",
        "responses": {"200": {"description": "Versioned roles and permissions", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminRoleCatalog"}}}}}
      }
    },
    "/api/v1/admin/system/status": {
      "get": {
        "operationId": "getAdminSystemStatus",
        "responses": {"200": {"description": "Real browser-safe subsystem checks", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminSystemStatus"}}}}}
      }
    },
    "/api/v1/admin/audit": {
      "get": {
        "operationId": "getAdminAuditLog",
        "parameters": [
          {"$ref": "#/components/parameters/AdminPage"},
          {"$ref": "#/components/parameters/AdminPageSize"},
          {"$ref": "#/components/parameters/AuditActor"},
          {"$ref": "#/components/parameters/AuditEventType"},
          {"$ref": "#/components/parameters/AuditOccurredFrom"},
          {"$ref": "#/components/parameters/AuditOccurredTo"},
          {"$ref": "#/components/parameters/AuditSort"}
        ],
        "responses": {
          "200": {"description": "Filtered append-only administrative events", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AdminAuditLog"}}}},
          "422": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/openapi.json": {
      "get": {"operationId": "getOpenApi", "responses": {"200": {"description": "This OpenAPI document"}}}
    },
    "/api/v1/contracts/{contract_name}.json": {
      "get": {
        "operationId": "getContractSchema",
        "parameters": [{"$ref": "#/components/parameters/ContractName"}],
        "responses": {
          "200": {"description": "Published JSON Schema"},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/meta/errors": {
      "get": {
        "operationId": "getHttpErrorCatalog",
        "responses": {
          "200": {
            "description": "Stable HTTP errors and suggested user actions",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HttpErrorCatalog"}}}
          }
        }
      }
    },
    "/api/v1/meta/mmm-facts": {
      "get": {
        "operationId": "getMmmFactCatalog",
        "responses": {
          "200": {
            "description": "Reviewed static facts for the calculation progress screen",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MmmFactCatalog"}}}
          }
        }
      }
    },
    "/api/v1/meta/geo-catalog": {
      "get": {
        "operationId": "getGeoCatalogV1",
        "responses": {
          "200": {
            "description": "Complete versioned static geography catalog with canonical coordinates, source metadata and coverage",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GeoCatalogV1"}}}
          },
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/models/active": {
      "get": {
        "operationId": "getActiveModelPassport",
        "responses": {
          "200": {
            "description": "Verified research-serving model package",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ModelPassport"}}}
          },
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/models/active-v2": {
      "get": {
        "operationId": "getTurnoverOnlyModelPassport",
        "responses": {
          "200": {
            "description": "Turnover-only application-serving model passport",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ModelPassportV2"}}}
          },
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/calculation-profile": {
      "get": {
        "operationId": "getCalculationProfile",
        "responses": {
          "200": {
            "description": "Safe public calculation profile for the new-calculation flow",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CalculationProfile"}}}
          },
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/templates/campaign-plan.xlsx": {
      "get": {
        "operationId": "downloadCampaignPlanTemplate",
        "responses": {
          "200": {
            "description": "Synthetic XLSX template with daily and interval campaign layouts",
            "content": {
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {
                "schema": {"type": "string", "format": "binary"}
              }
            }
          }
        }
      }
    },
    "/api/v1/uploads": {
      "post": {
        "operationId": "createCampaignUpload",
        "parameters": [{"$ref": "#/components/parameters/IdempotencyKey"}],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {"file": {"type": "string", "format": "binary"}}
              }
            }
          }
        },
        "responses": {
          "200": {"$ref": "#/components/responses/CampaignUpload"},
          "202": {"$ref": "#/components/responses/CampaignUpload"},
          "400": {"$ref": "#/components/responses/ApiError"},
          "413": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/uploads/{upload_id}": {
      "get": {
        "operationId": "getCampaignUpload",
        "parameters": [{"$ref": "#/components/parameters/UploadId"}],
        "responses": {
          "200": {"$ref": "#/components/responses/CampaignUpload"},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/uploads/{upload_id}/validations": {
      "post": {
        "operationId": "createCampaignValidation",
        "parameters": [
          {"$ref": "#/components/parameters/UploadId"},
          {"$ref": "#/components/parameters/IdempotencyKey"}
        ],
        "responses": {
          "200": {"$ref": "#/components/responses/ValidationResult"},
          "202": {"$ref": "#/components/responses/ValidationResult"},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/validations/{validation_id}": {
      "get": {
        "operationId": "getCampaignValidation",
        "parameters": [{"$ref": "#/components/parameters/ValidationId"}],
        "responses": {
          "200": {"$ref": "#/components/responses/ValidationResult"},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/validations/{validation_id}/view-v2": {
      "get": {
        "operationId": "getTurnoverOnlyValidationView",
        "parameters": [{"$ref": "#/components/parameters/ValidationId"}],
        "responses": {
          "200": {
            "description": "File validation, turnover-model limitations, canonical geo normalization and map coverage without geo loss",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ValidationResultV2"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/validations/{validation_id}/jobs": {
      "post": {
        "operationId": "createDecisionJobFromValidation",
        "parameters": [
          {"$ref": "#/components/parameters/ValidationId"},
          {"$ref": "#/components/parameters/IdempotencyKey"}
        ],
        "requestBody": {
          "required": false,
          "content": {"application/json": {"schema": {"type": "object"}}}
        },
        "responses": {
          "200": {"$ref": "#/components/responses/DecisionJob"},
          "202": {"$ref": "#/components/responses/DecisionJob"},
          "409": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/workspace/home": {
      "get": {
        "operationId": "getWorkspaceHome",
        "responses": {
          "200": {
            "description": "Browser-safe workspace summary from persisted calculations and active model facts",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/WorkspaceHome"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/workspace/geo-budget": {
      "get": {
        "operationId": "getWorkspaceGeoBudget",
        "responses": {
          "200": {
            "description": "Server-aggregated campaign budgets by canonical geography identity with explicit unlocated budget coverage",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/WorkspaceGeoBudgetV1"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/calculations/history": {
      "get": {
        "operationId": "getCalculationHistory",
        "parameters": [
          {"$ref": "#/components/parameters/HistoryPage"},
          {"$ref": "#/components/parameters/HistoryPageSize"},
          {"$ref": "#/components/parameters/HistoryStatus"},
          {"$ref": "#/components/parameters/HistorySearch"},
          {"$ref": "#/components/parameters/HistoryCreatedFrom"},
          {"$ref": "#/components/parameters/HistoryCreatedTo"},
          {"$ref": "#/components/parameters/HistorySort"}
        ],
        "responses": {
          "200": {
            "description": "Server-filtered, stably ordered and paginated calculation history",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CalculationHistory"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/model/overview": {
      "get": {
        "operationId": "getModelOverview",
        "responses": {
          "200": {
            "description": "Browser-safe active model explanation and real registered versions",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ModelOverview"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/model/overview-v2": {
      "get": {
        "operationId": "getTurnoverOnlyModelOverview",
        "responses": {
          "200": {
            "description": "Turnover-only model overview for browser product pages",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ModelOverviewV2"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/model/historical-geo-budget": {
      "get": {
        "operationId": "getHistoricalModelGeoBudget",
        "responses": {
          "200": {
            "description": "Historical media spend from the active model panel, aggregated by canonical geography",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HistoricalModelGeoBudgetV1"}}}
          },
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/help/catalog": {
      "get": {
        "operationId": "getHelpCatalog",
        "responses": {
          "200": {
            "description": "Versioned structured help catalog with safe internal routes",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HelpCatalog"}}}
          },
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "operationId": "listDecisionJobs",
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "minimum": 1, "maximum": 200, "default": 50}},
          {"name": "offset", "in": "query", "schema": {"type": "integer", "minimum": 0, "default": 0}},
          {"name": "status", "in": "query", "schema": {"$ref": "#/components/schemas/JobStatus"}}
        ],
        "responses": {
          "200": {
            "description": "Paged jobs ordered newest first",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JobList"}}}
          },
          "400": {"$ref": "#/components/responses/ApiError"}
        }
      },
      "post": {
        "operationId": "submitDecisionJobContract",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionJob"}}}
        },
        "responses": {
          "200": {"$ref": "#/components/responses/DecisionJob"},
          "202": {"$ref": "#/components/responses/DecisionJob"},
          "422": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}": {
      "get": {
        "operationId": "getDecisionJob",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {"200": {"$ref": "#/components/responses/DecisionJob"}, "404": {"$ref": "#/components/responses/ApiError"}}
      }
    },
    "/api/v1/jobs/{job_id}/progress": {
      "get": {
        "operationId": "getJobProgress",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {"200": {"description": "ProgressEvent v1 array"}, "404": {"$ref": "#/components/responses/ApiError"}}
      }
    },
    "/api/v1/jobs/{job_id}/progress-view": {
      "get": {
        "operationId": "getJobProgressView",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {
          "200": {
            "description": "Browser-safe nine-stage calculation progress",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JobProgressView"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/errors": {
      "get": {
        "operationId": "getJobErrors",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {"200": {"description": "ApplicationError v1 array"}, "404": {"$ref": "#/components/responses/ApiError"}}
      }
    },
    "/api/v1/jobs/{job_id}/result": {
      "get": {
        "operationId": "getDecisionResult",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {
          "200": {"description": "Full audit result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/DecisionResult"}}}},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/overview": {
      "get": {
        "operationId": "getResultOverview",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {
          "200": {"description": "Browser-oriented result", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ResultOverview"}}}},
          "404": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/result-view": {
      "get": {
        "operationId": "getJobResultView",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {
          "200": {
            "description": "Browser-safe four-tab product result projection",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JobResultView"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/result-view-v2": {
      "get": {
        "operationId": "getTurnoverOnlyJobResultView",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {
          "200": {
            "description": "Turnover-only scenario result with explicit budget, ROAS and risk semantics",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JobResultViewV2"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/media-plan": {
      "get": {
        "operationId": "getScenarioMediaPlan",
        "parameters": [
          {"$ref": "#/components/parameters/JobId"},
          {"$ref": "#/components/parameters/ScenarioId"},
          {"$ref": "#/components/parameters/Page"},
          {"$ref": "#/components/parameters/PageSize"},
          {"$ref": "#/components/parameters/ChannelFilter"},
          {"$ref": "#/components/parameters/GeoFilter"},
          {"$ref": "#/components/parameters/DateFilter"}
        ],
        "responses": {
          "200": {
            "description": "Hash-verified paginated scenario media plan at geo-by-channel total grain",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ScenarioMediaPlan"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/media-plan-v2": {
      "get": {
        "operationId": "getTurnoverOnlyScenarioMediaPlan",
        "parameters": [
          {"$ref": "#/components/parameters/JobId"},
          {"$ref": "#/components/parameters/ScenarioId"},
          {"$ref": "#/components/parameters/Page"},
          {"$ref": "#/components/parameters/PageSize"},
          {"$ref": "#/components/parameters/ChannelFilter"},
          {"$ref": "#/components/parameters/GeoFilter"},
          {"$ref": "#/components/parameters/DateFilter"}
        ],
        "responses": {
          "200": {
            "description": "Turnover-only media plan with stable channel and geography identities",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ScenarioMediaPlanV2"}}}
          },
          "404": {"$ref": "#/components/responses/ApiError"},
          "409": {"$ref": "#/components/responses/ApiError"},
          "422": {"$ref": "#/components/responses/ApiError"},
          "503": {"$ref": "#/components/responses/ApiError"}
        }
      }
    },
    "/api/v1/jobs/{job_id}/cancel": {
      "post": {
        "operationId": "requestJobCancellation",
        "parameters": [{"$ref": "#/components/parameters/JobId"}],
        "responses": {"202": {"description": "Cancellation requested"}, "409": {"$ref": "#/components/responses/ApiError"}}
      }
    },
