{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmm-platform.local/contracts/model_passport_v2.schema.json",
  "title": "ModelPassportV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_name", "schema_version", "record_origin", "serving", "package", "data", "coverage", "validation", "channel_policies", "caveats"],
  "properties": {
    "contract_name": {"const": "model_passport_v2"},
    "schema_version": {"const": "2.0.0"},
    "record_origin": {"enum": ["verified_model_package", "synthetic_fixture"]},
    "serving": {"$ref": "#/$defs/serving"},
    "package": {"$ref": "#/$defs/package"},
    "data": {"$ref": "#/$defs/data"},
    "coverage": {"$ref": "#/$defs/coverage"},
    "validation": {"$ref": "#/$defs/validation"},
    "channel_policies": {"type": "array", "items": {"$ref": "#/$defs/channelPolicy"}},
    "caveats": {"type": "array", "items": {"$ref": "#/$defs/status"}}
  },
  "$defs": {
    "nonEmptyText": {"type": "string", "minLength": 1},
    "nullableText": {"type": ["string", "null"]},
    "period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date"],
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"}
      }
    },
    "developmentPeriod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_date", "end_date", "purpose"],
      "properties": {
        "start_date": {"type": ["string", "null"], "format": "date"},
        "end_date": {"type": ["string", "null"], "format": "date"},
        "purpose": {"const": "development_shadow_not_sealed_oot"}
      }
    },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "display_text"],
      "properties": {
        "code": {"$ref": "#/$defs/nonEmptyText"},
        "display_text": {"$ref": "#/$defs/nonEmptyText"}
      }
    },
    "evidenceStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "generated_at_utc", "reason_code", "display_text"],
      "properties": {
        "status": {"enum": ["passed", "unavailable", "failed"]},
        "generated_at_utc": {"$ref": "#/$defs/nullableText"},
        "reason_code": {"$ref": "#/$defs/nullableText"},
        "display_text": {"$ref": "#/$defs/nonEmptyText"}
      }
    },
    "channel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel_id", "channel_display_name"],
      "properties": {
        "channel_id": {"$ref": "#/$defs/nonEmptyText"},
        "channel_display_name": {"$ref": "#/$defs/nonEmptyText"}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "core_target"],
      "properties": {
        "target_id": {"const": "turnover"},
        "core_target": {"const": "turnover_per_user"}
      }
    },
    "serving": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serving_policy_version", "target_id", "core_target", "serving_targets_n", "active_serving_models_n", "research_models_in_package_n", "calculation_allowed", "production_claim_allowed"],
      "properties": {
        "serving_policy_version": {"const": "turnover_serving_v1"},
        "target_id": {"const": "turnover"},
        "core_target": {"const": "turnover_per_user"},
        "serving_targets_n": {"const": 1},
        "active_serving_models_n": {"const": 4},
        "research_models_in_package_n": {"const": 12},
        "calculation_allowed": {"type": "boolean"},
        "production_claim_allowed": {"const": false}
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_channel", "registry_event_id", "package_id", "package_fingerprint", "model_run_id", "package_stage", "activation_status", "package_schema_version", "gate_policy_version"],
      "properties": {
        "registry_channel": {"$ref": "#/$defs/nonEmptyText"},
        "registry_event_id": {"$ref": "#/$defs/nonEmptyText"},
        "package_id": {"type": "string", "pattern": "^pkg_[0-9a-f]{16}_[0-9a-f]{16}$"},
        "package_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "model_run_id": {"$ref": "#/$defs/nonEmptyText"},
        "package_stage": {"$ref": "#/$defs/nonEmptyText"},
        "activation_status": {"$ref": "#/$defs/nonEmptyText"},
        "package_schema_version": {"$ref": "#/$defs/nonEmptyText"},
        "gate_policy_version": {"$ref": "#/$defs/nonEmptyText"}
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grain", "training_period", "development_shadow_period"],
      "properties": {
        "grain": {"const": "daily"},
        "training_period": {"$ref": "#/$defs/period"},
        "development_shadow_period": {"$ref": "#/$defs/developmentPeriod"}
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segments", "channels", "targets", "geographies_n", "capability_cells_n"],
      "properties": {
        "segments": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmptyText"}},
        "channels": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/channel"}},
        "targets": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"$ref": "#/$defs/target"}},
        "geographies_n": {"type": "integer", "minimum": 0},
        "capability_cells_n": {"type": "integer", "minimum": 0}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["historical_replay", "sealed_oot", "production_blockers"],
      "properties": {
        "historical_replay": {"$ref": "#/$defs/evidenceStatus"},
        "sealed_oot": {"$ref": "#/$defs/evidenceStatus"},
        "production_blockers": {"type": "array", "items": {"$ref": "#/$defs/status"}}
      }
    },
    "channelPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["segment", "channel_id", "channel_display_name", "target", "allowed_use", "forecast_action", "optimizer_action", "display_text"],
      "properties": {
        "segment": {"$ref": "#/$defs/nonEmptyText"},
        "channel_id": {"$ref": "#/$defs/nonEmptyText"},
        "channel_display_name": {"$ref": "#/$defs/nonEmptyText"},
        "target": {"const": "turnover"},
        "allowed_use": {"$ref": "#/$defs/nonEmptyText"},
        "forecast_action": {"$ref": "#/$defs/nonEmptyText"},
        "optimizer_action": {"$ref": "#/$defs/nonEmptyText"},
        "display_text": {"$ref": "#/$defs/nonEmptyText"}
      }
    }
  }
}
