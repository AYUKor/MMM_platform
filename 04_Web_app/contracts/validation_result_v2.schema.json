{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mmm-platform.local/contracts/validation_result_v2.schema.json",
  "title": "ValidationResultV2",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_name", "schema_version", "validation_id", "status", "job_creation_allowed", "file_validation", "model_limitations", "geo_points"],
  "properties": {
    "contract_name": {"const": "validation_result_v2"},
    "schema_version": {"const": "2.0.0"},
    "validation_id": {"type": "string"},
    "status": {"enum": ["passed", "warning", "failed", "unavailable"]},
    "job_creation_allowed": {"type": "boolean"},
    "file_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rows_n", "campaigns_n", "geographies_n", "channels_n", "requested_budget_rub", "blocking_errors_n", "warnings_n", "checks"],
      "properties": {
        "status": {"enum": ["passed", "warning", "failed", "unavailable"]},
        "rows_n": {"type": "integer", "minimum": 0},
        "campaigns_n": {"type": "integer", "minimum": 0},
        "geographies_n": {"type": "integer", "minimum": 0},
        "channels_n": {"type": "integer", "minimum": 0},
        "requested_budget_rub": {"type": "number", "minimum": 0},
        "blocking_errors_n": {"type": "integer", "minimum": 0},
        "warnings_n": {"type": "integer", "minimum": 0},
        "checks": {"type": "array", "items": {"type": "object", "required": ["code", "status", "display_text"], "properties": {"code": {"type": "string"}, "status": {"enum": ["passed", "warning", "failed", "unavailable"]}, "display_text": {"type": "string"}}, "additionalProperties": false}}
      }
    },
    "model_limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "channel_id", "channel_display_name", "limitation_type", "affected_geos_n", "affected_geos", "severity", "allowed_use", "blocks_calculation", "what", "why", "recommended_action"],
        "properties": {
          "target": {"const": "turnover"},
          "channel_id": {"type": "string"},
          "channel_display_name": {"type": "string"},
          "limitation_type": {"type": "string"},
          "affected_geos_n": {"type": "integer", "minimum": 0},
          "affected_geos": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "severity": {"enum": ["information", "warning", "manual_review", "blocking"]},
          "allowed_use": {"enum": ["primary", "caution", "diagnostic", "unsupported", "unavailable"]},
          "blocks_calculation": {"type": "boolean"},
          "what": {"type": "string"},
          "why": {"type": "string"},
          "recommended_action": {"type": "string"}
        }
      }
    },
    "geo_points": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["geo_id", "geo_display_name", "latitude", "longitude", "coordinates_status", "budget_rub", "budget_share", "channels", "has_model_limitations"],
        "properties": {
        "geo_id": {"type": "string", "pattern": "^geo_[0-9a-f]{16}$"},
        "geo_display_name": {"type": "string", "minLength": 1},
        "latitude": {"type": ["number", "null"], "minimum": -90, "maximum": 90},
        "longitude": {"type": ["number", "null"], "minimum": -180, "maximum": 180},
          "coordinates_status": {"enum": ["canonical", "unavailable"]},
          "budget_rub": {"type": "number", "minimum": 0},
          "budget_share": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "channels": {"type": "array", "items": {"type": "object", "required": ["channel_id", "channel_display_name"], "properties": {"channel_id": {"type": "string"}, "channel_display_name": {"type": "string"}}, "additionalProperties": false}},
          "has_model_limitations": {"type": "boolean"}
        }
      }
    }
  }
}
